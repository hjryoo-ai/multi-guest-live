{
  "name": "multi-live",
  "version": "0.0.0",
  "private": true,
  "description": "멀티 게스트 라이브 스트리밍 시스템 (LiveKit SFU 기반)",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:generate": "pnpm --filter @multi-live/api db:generate",
    "db:migrate": "pnpm --filter @multi-live/api db:migrate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
