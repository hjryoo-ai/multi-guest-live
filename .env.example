# ─── LiveKit ───────────────────────────────────────────────
# 아래는 self-host(OSS 컨테이너) dev 값. livekit.yaml 의 keys 항목과 반드시 일치해야 함.
# LiveKit Cloud 전환 시(배포): 대시보드의 키/시크릿과 프로젝트 주소로 교체.
#   서버(api)와 브라우저(web)는 같은 호스트를 다른 스킴으로 쓴다:
#     LIVEKIT_URL            = 서버 SDK(RoomServiceClient/Egress) → http/https  (Cloud: https://<project>.livekit.cloud)
#     NEXT_PUBLIC_LIVEKIT_URL= 브라우저(LiveKitRoom serverUrl)   → ws/wss       (Cloud: wss://<project>.livekit.cloud)
#   ※ 프로덕션(NODE_ENV=production) 부트는 dev 값(devkey·http://localhost·ws://)을 거부한다(fail-fast).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_0123456789abcdef
LIVEKIT_URL=http://localhost:7880
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─── API ───────────────────────────────────────────────────
API_PORT=4000
# web 에서 api 를 호출하는 공개 베이스 URL(HLS 매니페스트 URL 생성에도 사용).
# 프로덕션은 https 비-로컬 필수(예: https://api.example.com) — 부트에서 검증.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://multilive:multilive@localhost:5432/multilive

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (간이) ────────────────────────────────────────────
# 세션/JWT 서명용 시크릿 (실서비스 인증은 범위 외)
AUTH_SECRET=dev_auth_secret_change_me

# ─── Phase 5 (선택) ─────────────────────────────────────────
# /metrics 보호: 설정 시 Bearer 검증, 미설정 시 무인증(운영망 전제).
# METRICS_TOKEN=
# LiveKit AccessToken TTL(초). 기본 600. 재접속 통합 테스트 시 짧게(예: 6).
# TOKEN_TTL_SEC=600
# host 이탈 유예(초). 기본 60. 미복귀 시 방 자동 종료.
# HOST_GRACE_SEC=60
# HLS egress 산출물 디렉터리(정적 /hls 서빙). 기본 <repo>/egress-out.
# EGRESS_OUT_DIR=

# ─── Phase 7-lite: 데모 가드 (선택) ─────────────────────────
# 전부 기본 0 = 해당 가드 비활성(dev/E2E 무영향). 데모 배포에서만 켠다. 상세: docs/demo-mode.md
# 동시 활성 방 상한(created|live). 초과 시 방 생성 503 demo_room_cap.
# MAX_CONCURRENT_ROOMS=20
# 방 최대 수명(분). 생성 후 초과 시 자동 종료(host 유예와 동일 종료 경로).
# MAX_ROOM_LIFETIME_MIN=60
# 데이터 보존(시간). 종료 후 초과한 방·채팅·로그·참가자·고아 익명 user 삭제(프라이버시).
# DATA_RETENTION_HOURS=24

# ─── Phase 7-lite: 리버스 프록시 (선택) ─────────────────────
# 리버스 프록시(Caddy 등) 뒤에서 실행할 때만 설정. 미설정=직결(XFF 불신, req.ip=소켓).
#   프로덕션(Caddy 1대 뒤): TRUST_PROXY=1   ← 오른쪽 1홉만 신뢰 → leftmost 위조 XFF 무력화
#   특정 프록시 IP/서브넷:   TRUST_PROXY=10.0.0.0/8,127.0.0.1
# 잘못된 형식은 부트에서 즉시 거부(fail-fast). 배선 가이드: docs/deploy/reverse-proxy.md
# TRUST_PROXY=

# ─── Phase 6.5 하드닝 (선택) ────────────────────────────────
# 실행 환경. production 이면 부트에서 시크릿 강도·CORS 를 강제 검증(fail-fast).
# NODE_ENV=development
# CORS 허용 오리진(콤마 구분). 프로덕션 필수 · '*' 금지. 미설정 시 개발 기본(localhost:3000).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# 요청 body 상한(바이트). 기본 1MB.
# BODY_LIMIT_BYTES=1048576
#
# ※ 프로덕션(NODE_ENV=production) 부트 요건:
#    - AUTH_SECRET / LIVEKIT_API_SECRET: 32자 이상 · 기본/약한 값(devkey 등) 금지
#    - LIVEKIT_API_KEY: 기본값(devkey) 금지
#    - CORS_ORIGINS: 명시 필수 · '*' 금지
#    위반 시 서버가 원인 키를 출력하고 부트 실패한다.
