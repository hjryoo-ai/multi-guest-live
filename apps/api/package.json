{
  "name": "@multi-live/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "verify:phase1": "tsx scripts/verify-phase1.ts",
    "verify:phase2": "tsx scripts/verify-phase2.ts",
    "verify:phase3": "tsx scripts/verify-phase3.ts",
    "verify:phase4": "tsx scripts/verify-phase4.ts",
    "verify:phase5": "tsx scripts/verify-phase5.ts",
    "verify:phase6a": "tsx scripts/verify-phase6a.ts",
    "verify:phase6b": "tsx scripts/verify-phase6b.ts",
    "verify:phase65a": "tsx scripts/verify-phase65a.ts",
    "verify:phase65b": "tsx scripts/verify-phase65b.ts",
    "verify:phase65c": "tsx scripts/verify-phase65c.ts",
    "verify:phase7": "tsx scripts/verify-phase7.ts",
    "verify:phase7demo": "tsx scripts/verify-phase7demo.ts",
    "verify:phase7timeout": "tsx scripts/verify-phase7timeout.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^8.0.3",
    "@multi-live/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "livekit-server-sdk": "^2.9.2",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
